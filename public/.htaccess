# ======================================================================
# Rational Real Estate — Hostinger .htaccess
# ======================================================================

# ----------------------------------------------------------------------
# Force HTTPS + non-www to www (uncomment if you prefer non-www, switch the rules)
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS
  RewriteCond %{HTTPS} !=on
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Force www (optional — comment out if you want bare domain)
  RewriteCond %{HTTP_HOST} ^rationalrealestate\.in$ [NC]
  RewriteRule ^(.*)$ https://www.rationalrealestate.in/$1 [L,R=301]
</IfModule>

# ----------------------------------------------------------------------
# SPA routing — send every non-file request to index.html
# Required for React Router client-side routes like /about, /services, etc.
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Pass through real files and directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else → index.html
  RewriteRule ^ index.html [L]
</IfModule>

# ----------------------------------------------------------------------
# Gzip / Deflate compression
# ----------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml application/rss+xml
  AddOutputFilterByType DEFLATE image/svg+xml font/ttf font/otf application/font-woff application/font-woff2
</IfModule>

# ----------------------------------------------------------------------
# Browser caching
# ----------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"

  # HTML — short TTL so new deploys show up quickly
  ExpiresByType text/html "access plus 0 seconds"

  # Hashed build assets (JS/CSS) — long TTL, immutable
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/x-javascript "access plus 1 year"

  # Images / fonts
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"

  # SEO files — refresh daily
  ExpiresByType application/xml "access plus 1 day"
  ExpiresByType text/xml "access plus 1 day"
  ExpiresByType text/plain "access plus 1 day"
</IfModule>

<IfModule mod_headers.c>
  # Hashed assets under /assets/ are content-addressed by Vite — safe to cache forever
  <FilesMatch "\.(js|css|woff2|woff|ttf|otf|svg|jpg|jpeg|png|gif|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Never cache the HTML entry — ensures users get the latest app bundle
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

# ----------------------------------------------------------------------
# Security headers
# ----------------------------------------------------------------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
</IfModule>

# ----------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------
# Disable directory listing
Options -Indexes

# Default charset
AddDefaultCharset UTF-8

# Custom 404 → SPA handles the 404 UI after routing, but set a fallback
ErrorDocument 404 /index.html
